rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bands
    // Fields: name, genre, origin, videos, social, locality, status
    //
    // Collection: matches
    // Fields: band1Id, band2Id, date, band1Votes, band2Votes, status
    //
    // Collection: votes
    // Document ID: {matchId}_{userId}
    // Fields: matchId, bandId, userId, timestamp
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidVote(data) {
      return data.matchId is string && 
             data.bandId is string && 
             data.userId == request.auth.uid &&
             data.timestamp is timestamp;
    }

    function isAdmin() {
      return isAuthenticated() && 
             ((request.auth.token.email == "jantonyj2006@gmail.com" || request.auth.token.email == "lapd8402@gmail.com") && request.auth.token.email_verified == true);
    }

    match /bands/{bandId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /votes/{voteId} {
      // Allow authenticated users to read votes to see the scoreboard
      allow read: if isAuthenticated();
      
      // Allow users to create or update their own vote
      allow create, update: if isAuthenticated() && 
                           request.resource.data.userId == request.auth.uid &&
                           isValidVote(request.resource.data);
      
      allow delete: if false;
    }
  }
}
